# ----- Postgres -----
POSTGRES_DB=veg_fruit
POSTGRES_USER=veg_fruit
POSTGRES_PASSWORD=veg_fruit_password

# ----- Backend admin / JWT -----
ADMIN_LOGIN=miksgoldfruct
# Пароль только так, без каких-либо кавычек вокруг значения (иначе 401).
ADMIN_PASSWORD=Miksgold1!
JWT_SECRET=change_me_prod_jwt_secret
JWT_REFRESH_SECRET=change_me_prod_jwt_refresh_secret

# ----- CORS -----
# В проде поставьте ваш домен/айпи (например: http://178.172.201.107 или https://ваш-домен)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://178.172.201.107,http://miksgoldfruct.by,http://www.miksgoldfruct.by,https://miksgoldfruct.by,https://www.miksgoldfruct.by

# ----- Web port -----
WEB_PORT=80

# ----- Frontend (сборка / превью) -----
# В проде с Docker: обычно оставьте пустым (запросы с того же origin, nginx проксирует /api).
# Локально без прокси: VITE_API_BASE_URL=http://localhost:3001

VITE_API_BASE_URL=

# ----- Telegram (уведомления о новых заказах) -----
# 1) Создайте бота через @BotFather и получите токен.
# 2) Узнайте chat_id: для личного чата можно написать боту и посмотреть getUpdates,
#    для группы добавьте бота в группу и также возьмите chat_id (обычно отрицательное число).
#    Несколько чатов: через запятую, например TELEGRAM_CHAT_ID=111,222,-100123
# 3) Включите флаг TELEGRAM_ORDER_NOTIFICATIONS_ENABLED=true
TELEGRAM_ORDER_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

